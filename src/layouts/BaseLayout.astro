---
import "../styles/global.css";
import { SITE } from "../data/siteConfig";

const { title, description } = SITE;
const pageTitle = Astro.props.title ? `${Astro.props.title} | ${title}` : title;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: SITE.base, label: "Home" },
  { href: SITE.base + "projects/", label: "Projects" },
  { href: SITE.base + "experience/", label: "Experience" },
  { href: SITE.base + "paper/", label: "Papers" },
  { href: SITE.base + "about/", label: "About" },
  { href: SITE.base + "resume/", label: "Resume" },
  { href: SITE.base + "contact/", label: "Contact" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {SITE.analytics.plausibleDomain && (
      <script defer data-domain={SITE.analytics.plausibleDomain} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-frame flex flex-wrap items-start justify-between gap-4">
        <a href={SITE.base} class="brand-lockup">
          <span class="brand-mark">{SITE.title}</span>
          <span class="brand-name">Portfolio</span>
          <span class="brand-tag">{SITE.tag}</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navLinks.map((link) => (
            <a href={link.href} class:list={[currentPath === link.href && "is-active"]}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-frame">
        <div class="site-footer__inner">
          <div class="site-footer__copy">
            <span>&copy; {new Date().getFullYear()} {SITE.title}</span>
          </div>
          <div class="site-footer__links">
            <a href={SITE.github}>GitHub</a>
            <a href={SITE.linkedIn}>LinkedIn</a>
            <a href={"mailto:" + SITE.email}>Email</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
