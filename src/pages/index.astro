---
import ResumeDownloadButton from "../components/ResumeDownloadButton";
import ShowcaseCard from "../components/ShowcaseCard.astro";
import Base from "../layouts/BaseLayout.astro";
import { SITE } from "../data/siteConfig";

const resumePath = SITE.base + "resume.pdf";
const projectsHref = SITE.base + "projects/";
const experienceHref = SITE.base + "experience/";
const papersHref = SITE.base + "paper/";

const highlights = [
  {
    title: "Projects",
    eyebrow: "Simulation, robotics, and experimentation",
    meta: ["3 selected builds", "Python", "ROS 2"],
    img: SITE.base + "images/projects/qpitch.png",
    alt: "Visualization of pitch sequencing recommendations from a baseball model",
    desc:
      "See independent technical work across reinforcement learning, game simulation, and autonomous robot control.",
    href: projectsHref,
    cta: "Explore Projects",
  },
  {
    title: "Experience",
    eyebrow: "Applied systems and product work",
    meta: ["2 featured roles", "ML pipelines", "Full stack"],
    img: SITE.base + "images/projects/cw-pipeline.png",
    alt: "Archival preservation workflow and processed historical newspaper scans",
    desc:
      "Review hands-on work in archival machine learning pipelines and a collaborative web product build.",
    href: experienceHref,
    cta: "See Experience",
  },
  {
    title: "Papers",
    eyebrow: "Research and technical writing",
    meta: ["2 papers", "NLP", "Software testing"],
    img: SITE.base + "images/papers/phishing.png",
    alt: "Chart from phishing detection research paper",
    desc:
      "Read my phishing detection paper and a rapid literature review on reinforcement learning and large language models for software testing.",
    href: papersHref,
    cta: "Read Papers",
  },
];
---

<Base title="Home">
  <section class="card page-hero hero-panel mt-6">
    <div class="hero-panel__grid">
      <div>
        <p class="eyebrow">Computer Science M.S. Graduate</p>
        <h1 class="page-title max-w-4xl">Practical software, machine learning, and robotics built with care.</h1>
        <p class="page-copy max-w-2xl">
          I am Ryan Adolfs, a University of Alabama computer scientist building useful systems across
          machine learning pipelines, full-stack web applications, and autonomous robotics.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <ResumeDownloadButton client:load href={resumePath} filename="Ryan_Adolfs_Resume.pdf" />
          <a class="btn" href={projectsHref}>View Projects</a>
          <a class="btn" href={experienceHref}>View Experience</a>
          <a class="btn" href={papersHref}>View Papers</a>
          <a class="btn" href={SITE.base + "contact/"}>Contact</a>
        </div>
      </div>

      <aside class="signal-panel">
        <p class="eyebrow">Focus Areas</p>
        <ul class="signal-list">
          <li>
            <span class="signal-label">Machine Learning</span>
            <strong>Embeddings, retrieval workflows, and document classification.</strong>
          </li>
          <li>
            <span class="signal-label">Software Engineering</span>
            <strong>Full-stack delivery with attention to usable interfaces and reliable systems.</strong>
          </li>
          <li>
            <span class="signal-label">Robotics</span>
            <strong>ROS 2 control logic that moves from simulation into hardware.</strong>
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="mt-10">
    <p class="eyebrow">Portfolio Map</p>
    <h2 class="section-title mt-4 max-w-3xl">Start in the area that matches what you want to see.</h2>
    <p class="section-copy max-w-2xl">
      The site is split by how the work was done: independent builds under Projects, professional and
      academic roles under Experience, and formal research under Papers.
    </p>

    <div class="mt-8 grid gap-6 xl:grid-cols-3">
      {highlights.map((item) => (
        <ShowcaseCard {...item} />
      ))}
    </div>
  </section>
</Base>
