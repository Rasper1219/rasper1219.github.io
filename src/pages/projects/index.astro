---
import ShowcaseCard from "../../components/ShowcaseCard.astro";
import Base from "../../layouts/BaseLayout.astro";
import { SITE } from "../../data/siteConfig";

const experienceHref = SITE.base + "experience/";

const projects = [
  {
    title: "Probabilistic TCG Optimizer",
    eyebrow: "Simulation and decision analysis",
    meta: ["Python", "Monte Carlo", "Pokemon TCG"],
    img: SITE.base + "images/projects/tcg-optimizer.jpg",
    alt: "Plots and tables from a Pokemon TCG Monte Carlo simulator",
    desc:
      "Built a Monte Carlo simulator for Pokemon TCG deck consistency, modeling search lines and prize outcomes to estimate how often a Stage 2 strategy comes online by turn. The tool compares deck changes across thousands of trials and surfaces which additions most improve early setup odds.",
  },
  {
    title: "Baseball Q-Learning Pitch Suggester",
    eyebrow: "Reinforcement learning",
    meta: ["Python", "Q-learning", "Baseball Savant"],
    img: SITE.base + "images/projects/qpitch.png",
    alt: "Baseball pitch chart with recommended sequences",
    desc:
      "Trained a Q-learning agent on Baseball Savant data to recommend pitch sequences based on count, state, and target outcome. The system simulates at-bats in a multidimensional state space and returns context-aware pitch plans for strikeouts, groundballs, or flyballs.",
  },
  {
    title: "Autonomous Mobile Robot Controller",
    eyebrow: "Robotics and control systems",
    meta: ["ROS 2", "Python", "Webots", "TurtleBot"],
    desc:
      "Built a ROS 2 Python controller for autonomous navigation in Webots and on TurtleBot hardware. The package processes LIDAR and odometry data to find walls, follow them, avoid obstacles, and support repeatable launches on both simulation and physical robots.",
    placeholderLabel: "Autonomy",
    placeholderTitle: "Autonomous Mobile Robot Controller",
    placeholderMeta: ["ROS 2", "LIDAR", "Odometry", "Ubuntu Linux"],
  },
];
---

<Base title="Projects">
  <section class="card page-hero mt-6">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Independent builds across simulation, learning, and robotics.</h1>
    <p class="page-copy max-w-3xl">
      This page holds work I built as standalone technical projects, from probabilistic modeling to
      reinforcement learning and autonomous robot control.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn" href={experienceHref}>View Experience</a>
      <a class="btn" href={SITE.base + "paper/"}>View Papers</a>
    </div>
  </section>

  <section class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {projects.map((item) => (
      <ShowcaseCard {...item} />
    ))}
  </section>
</Base>
